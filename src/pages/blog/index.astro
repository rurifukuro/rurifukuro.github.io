---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import TagBadge from '../../components/TagBadge.astro';
import { getCollection } from 'astro:content';
import { isDisplayTag } from '../../utils/tags';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const allTags = [...new Set(posts.flatMap((p) => p.data.tags))].filter(isDisplayTag).sort();
---

<BaseLayout title="イベント攻略ブログ｜瑠璃フクロウ">
  <div class="blog-page">
    <div class="hero">
      <div class="hero-glow"></div>
      <div class="hero-content">
        <a class="back" href="/">
          <span class="back-arrow">←</span>
          瑠璃フクロウ
        </a>
        <h1 class="hero-title">イベント<span class="grad">攻略</span>ブログ</h1>
        <p class="hero-lead">コミケ・コミティア・デザフェスなど<br class="sp-only" />同人イベントの攻略情報</p>
      </div>
    </div>

    <div class="content">
      <div class="tags-bar">
        {allTags.map((tag) => <TagBadge tag={tag} />)}
      </div>

      <div class="posts">
        {posts.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            tags={post.data.tags}
            category={post.data.category}
            slug={post.slug}
          />
        ))}
      </div>
    </div>

    <footer class="footer">
      © 瑠璃フクロウ ｜ <a href="https://x.com/rurifukuro">@rurifukuro</a> ｜
      <a href="mailto:rurifukuro@gmail.com">rurifukuro@gmail.com</a>
    </footer>
  </div>
</BaseLayout>

<style>
  .blog-page {
    min-height: 100vh;
  }

  .hero {
    position: relative;
    padding: 48px 24px 40px;
    text-align: center;
    overflow: hidden;
    background: linear-gradient(180deg, rgba(78,143,255,.08) 0%, transparent 100%);
    border-bottom: 1px solid rgba(255,255,255,.05);
  }

  .hero-glow {
    position: absolute;
    top: -120px;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 300px;
    background: radial-gradient(ellipse, rgba(245,130,31,.1) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 1;
  }

  .back {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: var(--text-muted);
    margin-bottom: 20px;
    transition: color .15s;
  }

  .back:hover {
    color: var(--text-sub);
    text-decoration: none;
  }

  .back-arrow {
    font-size: 11px;
  }

  .hero-title {
    font-size: 36px;
    font-weight: 900;
    letter-spacing: -.02em;
    line-height: 1.3;
  }

  .grad {
    background: linear-gradient(135deg, #f5821f 0%, #ffa94d 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-lead {
    font-size: 14px;
    color: var(--text-muted);
    margin-top: 12px;
    line-height: 1.7;
  }

  .content {
    max-width: 760px;
    margin: 0 auto;
    padding: 28px 24px 0;
  }

  .tags-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: center;
    margin-bottom: 36px;
  }

  .posts {
    display: grid;
    gap: 16px;
  }

  .footer {
    text-align: center;
    font-size: 12px;
    color: var(--text-dim);
    padding: 48px 24px 32px;
  }

  .footer a {
    color: var(--text-muted);
  }

  .sp-only {
    display: none;
  }

  @media (max-width: 480px) {
    .hero-title {
      font-size: 28px;
    }
    .sp-only {
      display: inline;
    }
  }
</style>
