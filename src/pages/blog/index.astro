---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import TagBadge from '../../components/TagBadge.astro';
import { getCollection } from 'astro:content';
import { isDisplayTag } from '../../utils/tags';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const allTags = [...new Set(posts.flatMap((p) => p.data.tags))].filter(isDisplayTag).sort();
const featuredPost = posts[0];
const gridPosts = posts.slice(1);
---

<BaseLayout title="イベント攻略ブログ｜瑠璃フクロウ">
  <div class="blog-page">
    <nav class="nav">
      <div class="nav-inner">
        <a class="nav-logo" href="/">瑠璃フクロウ</a>
        <a class="nav-link active" href="/blog/">ブログ</a>
      </div>
    </nav>

    <header class="hero">
      <div class="hero-inner">
        <p class="hero-label">BLOG</p>
        <h1 class="hero-title">イベント攻略ブログ</h1>
        <p class="hero-lead">コミケ・コミティア・デザフェスなど<br class="sp-only" />同人イベントの攻略情報を発信</p>
      </div>
    </header>

    <div class="content">
      <div class="tags-bar">
        {allTags.map((tag) => <TagBadge tag={tag} />)}
      </div>

      {featuredPost && (
        <a class="featured" href={`/blog/${featuredPost.slug}/`}>
          <div class="featured-accent"></div>
          <div class="featured-body">
            <div class="featured-meta">
              <span class="featured-category">{featuredPost.data.category}</span>
              <time datetime={featuredPost.data.date.toISOString().slice(0, 10)}>
                {featuredPost.data.date.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
            </div>
            <h2 class="featured-title">{featuredPost.data.title}</h2>
            <p class="featured-desc">{featuredPost.data.description}</p>
            <span class="featured-link">続きを読む &rarr;</span>
          </div>
        </a>
      )}

      <div class="grid">
        {gridPosts.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            tags={post.data.tags}
            category={post.data.category}
            slug={post.slug}
          />
        ))}
      </div>
    </div>

    <footer class="footer">
      <div class="footer-inner">
        <div class="footer-brand">瑠璃フクロウ</div>
        <div class="footer-links">
          <a href="https://x.com/rurifukuro">@rurifukuro</a>
          <span class="footer-dot">&middot;</span>
          <a href="mailto:rurifukuro@gmail.com">rurifukuro@gmail.com</a>
        </div>
        <p class="footer-copy">&copy; 瑠璃フクロウ</p>
      </div>
    </footer>
  </div>
</BaseLayout>

<style>
  .blog-page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  /* ── Navigation ── */
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(255, 255, 255, .92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .nav-inner {
    max-width: 960px;
    margin: 0 auto;
    padding: 14px 24px;
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .nav-logo {
    font-size: 16px;
    font-weight: 800;
    color: var(--text);
    letter-spacing: -.01em;
  }

  .nav-logo:hover {
    text-decoration: none;
    color: var(--accent);
  }

  .nav-link {
    font-size: 14px;
    font-weight: 600;
    color: var(--text-muted);
    position: relative;
    padding-bottom: 2px;
  }

  .nav-link:hover {
    color: var(--text);
    text-decoration: none;
  }

  .nav-link.active::after {
    content: '';
    position: absolute;
    bottom: -15px;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--accent);
    border-radius: 1px;
  }

  /* ── Hero ── */
  .hero {
    background: var(--bg-card);
    border-bottom: 1px solid var(--border);
    padding: 52px 24px 48px;
    text-align: center;
  }

  .hero-inner {
    max-width: 640px;
    margin: 0 auto;
  }

  .hero-label {
    font-size: 12px;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: .15em;
    margin-bottom: 12px;
  }

  .hero-title {
    font-size: 32px;
    font-weight: 900;
    line-height: 1.3;
    letter-spacing: -.02em;
    color: var(--text);
  }

  .hero-lead {
    font-size: 15px;
    color: var(--text-muted);
    margin-top: 12px;
    line-height: 1.7;
  }

  /* ── Content ── */
  .content {
    max-width: 960px;
    margin: 0 auto;
    padding: 32px 24px 56px;
    flex: 1;
  }

  .tags-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: center;
    margin-bottom: 32px;
  }

  /* ── Featured Card ── */
  .featured {
    display: flex;
    text-decoration: none;
    color: var(--text);
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    margin-bottom: 24px;
    transition: all 0.25s ease;
    box-shadow: var(--shadow-sm);
  }

  .featured:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-hover);
    border-color: var(--accent-border);
    text-decoration: none;
  }

  .featured-accent {
    width: 6px;
    flex-shrink: 0;
    background: linear-gradient(180deg, var(--accent), var(--accent-hover));
  }

  .featured-body {
    padding: 32px;
    flex: 1;
  }

  .featured-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 13px;
    color: var(--text-muted);
    margin-bottom: 14px;
  }

  .featured-category {
    font-size: 11px;
    font-weight: 700;
    color: var(--accent);
    background: var(--accent-soft);
    padding: 3px 12px;
    border-radius: 4px;
    letter-spacing: .04em;
  }

  .featured-title {
    font-size: 24px;
    font-weight: 800;
    line-height: 1.45;
    letter-spacing: -.01em;
    margin-bottom: 12px;
  }

  .featured-desc {
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 16px;
  }

  .featured-link {
    font-size: 14px;
    font-weight: 700;
    color: var(--accent);
  }

  /* ── Posts Grid ── */
  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  /* ── Footer ── */
  .footer {
    background: #1a1a2e;
    color: #b5b5c8;
    padding: 40px 24px;
    margin-top: auto;
  }

  .footer-inner {
    max-width: 960px;
    margin: 0 auto;
    text-align: center;
  }

  .footer-brand {
    font-size: 16px;
    font-weight: 800;
    color: #fff;
    margin-bottom: 10px;
  }

  .footer-links {
    font-size: 13px;
    margin-bottom: 16px;
  }

  .footer-links a {
    color: #8c8ca1;
    transition: color .15s;
  }

  .footer-links a:hover {
    color: #fff;
    text-decoration: none;
  }

  .footer-dot {
    margin: 0 8px;
    opacity: .4;
  }

  .footer-copy {
    font-size: 12px;
    color: #666;
  }

  .sp-only {
    display: none;
  }

  @media (max-width: 640px) {
    .hero-title {
      font-size: 26px;
    }
    .sp-only {
      display: inline;
    }
    .grid {
      grid-template-columns: 1fr;
    }
    .featured-title {
      font-size: 20px;
    }
    .featured-body {
      padding: 24px;
    }
  }
</style>
