---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BlogCard from '../../../components/BlogCard.astro';
import TagBadge from '../../../components/TagBadge.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const tags = [...new Set(posts.flatMap((p) => p.data.tags))];
  return tags.map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: posts
        .filter((p) => p.data.tags.includes(tag))
        .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
    },
  }));
}

const { tag, posts } = Astro.props;
---

<BaseLayout title={`「${tag}」の記事一覧｜瑠璃フクロウ`}>
  <div class="wrap">
    <nav class="nav">
      <a class="backlink" href="/blog/">← 記事一覧に戻る</a>
    </nav>

    <header class="header">
      <p class="label">タグ</p>
      <h1 class="title">{tag}</h1>
      <p class="count">{posts.length}件の記事</p>
    </header>

    <div class="posts">
      {posts.map((post) => (
        <BlogCard
          title={post.data.title}
          description={post.data.description}
          date={post.data.date}
          tags={post.data.tags}
          category={post.data.category}
          slug={post.slug}
        />
      ))}
    </div>

    <footer class="footer">
      © 瑠璃フクロウ ｜ X：<a href="https://x.com/rurifukuro">@rurifukuro</a> ｜
      お問い合わせ：<a href="mailto:rurifukuro@gmail.com">rurifukuro@gmail.com</a>
    </footer>
  </div>
</BaseLayout>

<style>
  .wrap {
    max-width: 720px;
    margin: 0 auto;
    padding: 28px 24px 64px;
  }

  .nav {
    margin-bottom: 28px;
  }

  .backlink {
    font-size: 13px;
    color: #9fb0d4;
  }

  .backlink:hover {
    color: #cdd9f0;
    text-decoration: none;
  }

  .header {
    text-align: center;
    margin-bottom: 32px;
  }

  .label {
    font-size: 13px;
    color: #7f8eb0;
  }

  .title {
    font-size: 28px;
    font-weight: 800;
    margin-top: 4px;
    color: #f5821f;
  }

  .count {
    font-size: 14px;
    color: #9fb0d4;
    margin-top: 6px;
  }

  .posts {
    display: grid;
    gap: 16px;
  }

  .footer {
    text-align: center;
    font-size: 12px;
    color: #7f8eb0;
    margin-top: 52px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: 24px;
  }

  .footer a {
    color: #9fb0d4;
  }
</style>
