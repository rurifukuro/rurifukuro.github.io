---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BlogCard from '../../../components/BlogCard.astro';
import PopularSidebar from '../../../components/PopularSidebar.astro';
import RecommendedSidebar from '../../../components/RecommendedSidebar.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = (await getCollection('blog')).filter((p) => !p.data.draft);
  const tags = [...new Set(posts.flatMap((p) => p.data.tags))];
  return tags.map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: posts
        .filter((p) => p.data.tags.includes(tag))
        .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
    },
  }));
}

const { tag, posts } = Astro.props;
---

<BaseLayout title={`「${tag}」の記事一覧｜瑠璃フクロウ`}>
  <div class="page">
    <nav class="nav">
      <div class="nav-inner">
        <a class="nav-logo" href="/">瑠璃フクロウ</a>
        <div class="breadcrumb">
          <a class="breadcrumb-link" href="/blog/">ブログ</a>
          <span class="breadcrumb-sep">&rsaquo;</span>
          <span class="breadcrumb-current">タグ</span>
        </div>
      </div>
    </nav>

    <div class="tag-header">
      <p class="label">タグ</p>
      <h1 class="tag-title">{tag}</h1>
      <p class="count">{posts.length}件の記事</p>
    </div>

    <div class="blog-layout">
      <aside class="sidebar sidebar-left">
        <PopularSidebar />
      </aside>

      <main class="main-content">
        <div class="posts">
          {posts.map((post) => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              date={post.data.date}
              tags={post.data.tags}
              category={post.data.category}
              slug={post.slug}
            />
          ))}
        </div>
      </main>

      <aside class="sidebar sidebar-right">
        <RecommendedSidebar />
      </aside>
    </div>

    <footer class="footer">
      <div class="footer-inner">
        <div class="footer-brand">瑠璃フクロウ</div>
        <div class="footer-links">
          <a href="https://x.com/rurifukuro">@rurifukuro</a>
          <span class="footer-dot">&middot;</span>
          <a href="mailto:rurifukuro@gmail.com">rurifukuro@gmail.com</a>
        </div>
        <p class="footer-copy">&copy; 瑠璃フクロウ</p>
      </div>
    </footer>
  </div>
</BaseLayout>

<style>
  .page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(255, 255, 255, .92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 14px 24px;
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .nav-logo {
    font-size: 16px;
    font-weight: 800;
    color: var(--text);
    letter-spacing: -.01em;
    flex-shrink: 0;
  }

  .nav-logo:hover {
    text-decoration: none;
    color: var(--accent);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--text-muted);
  }

  .breadcrumb-link {
    color: var(--text-muted);
  }

  .breadcrumb-link:hover {
    color: var(--text);
    text-decoration: none;
  }

  .breadcrumb-sep {
    color: var(--text-dim);
  }

  .breadcrumb-current {
    color: var(--text-secondary);
    font-weight: 600;
  }

  .tag-header {
    text-align: center;
    padding: 40px 24px 32px;
    background: var(--bg-card);
    border-bottom: 1px solid var(--border);
  }

  .label {
    font-size: 12px;
    font-weight: 700;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: .1em;
  }

  .tag-title {
    font-size: 28px;
    font-weight: 900;
    margin-top: 6px;
    color: var(--accent);
    letter-spacing: -.01em;
  }

  .count {
    font-size: 13px;
    color: var(--text-muted);
    margin-top: 8px;
  }

  .posts {
    display: grid;
    gap: 16px;
  }

  .footer {
    background: #1a1a2e;
    color: #b5b5c8;
    padding: 40px 24px;
    margin-top: auto;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
  }

  .footer-brand {
    font-size: 16px;
    font-weight: 800;
    color: #fff;
    margin-bottom: 10px;
  }

  .footer-links {
    font-size: 13px;
    margin-bottom: 16px;
  }

  .footer-links a {
    color: #8c8ca1;
    transition: color .15s;
  }

  .footer-links a:hover {
    color: #fff;
    text-decoration: none;
  }

  .footer-dot {
    margin: 0 8px;
    opacity: .4;
  }

  .footer-copy {
    font-size: 12px;
    color: #666;
  }
</style>
