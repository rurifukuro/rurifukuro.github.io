---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BlogCard from '../../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const tags = [...new Set(posts.flatMap((p) => p.data.tags))];
  return tags.map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: posts
        .filter((p) => p.data.tags.includes(tag))
        .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
    },
  }));
}

const { tag, posts } = Astro.props;
---

<BaseLayout title={`「${tag}」の記事一覧｜瑠璃フクロウ`}>
  <div class="page">
    <div class="top-bar">
      <div class="top-inner">
        <a class="back" href="/blog/">
          <span class="back-arrow">←</span>
          記事一覧
        </a>
      </div>
    </div>

    <div class="content">
      <header class="header">
        <p class="label">タグ</p>
        <h1 class="title">{tag}</h1>
        <p class="count">{posts.length}件の記事</p>
      </header>

      <div class="posts">
        {posts.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            tags={post.data.tags}
            category={post.data.category}
            slug={post.slug}
          />
        ))}
      </div>
    </div>

    <footer class="footer">
      © 瑠璃フクロウ ｜ <a href="https://x.com/rurifukuro">@rurifukuro</a> ｜
      <a href="mailto:rurifukuro@gmail.com">rurifukuro@gmail.com</a>
    </footer>
  </div>
</BaseLayout>

<style>
  .page {
    min-height: 100vh;
  }

  .top-bar {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(10, 22, 40, .85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255,255,255,.05);
  }

  .top-inner {
    max-width: 760px;
    margin: 0 auto;
    padding: 12px 24px;
  }

  .back {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-weight: 600;
    color: var(--text-muted);
    transition: color .15s;
  }

  .back:hover {
    color: var(--text);
    text-decoration: none;
  }

  .back-arrow {
    font-size: 12px;
  }

  .content {
    max-width: 760px;
    margin: 0 auto;
    padding: 40px 24px 0;
  }

  .header {
    text-align: center;
    margin-bottom: 36px;
  }

  .label {
    font-size: 12px;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: .1em;
  }

  .title {
    font-size: 28px;
    font-weight: 800;
    margin-top: 4px;
    background: linear-gradient(135deg, var(--orange), #ffa94d);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .count {
    font-size: 13px;
    color: var(--text-muted);
    margin-top: 6px;
  }

  .posts {
    display: grid;
    gap: 16px;
  }

  .footer {
    text-align: center;
    font-size: 12px;
    color: var(--text-dim);
    padding: 48px 24px 32px;
  }

  .footer a {
    color: var(--text-muted);
  }
</style>
