---
import BaseLayout from './BaseLayout.astro';
import AppCTA from '../components/AppCTA.astro';
import TagBadge from '../components/TagBadge.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  category: string;
  targetApp: 'torehan' | 'urehan' | 'both';
}

const { title, description, date, tags, category, targetApp } = Astro.props;

const dateStr = date.toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${title}｜瑠璃フクロウ`} description={description} ogType="article">
  <div class="blog-wrap">
    <nav class="blog-nav">
      <a href="/blog/">← 記事一覧に戻る</a>
    </nav>

    <article class="article">
      <header class="article-header">
        <div class="article-meta">
          <time datetime={date.toISOString().slice(0, 10)}>{dateStr}</time>
          <span class="article-category">{category}</span>
        </div>
        <h1 class="article-title">{title}</h1>
        <div class="article-tags">
          {tags.map((tag) => <TagBadge tag={tag} />)}
        </div>
      </header>

      <div class="article-body">
        <slot />
      </div>

      <AppCTA app={targetApp} />
    </article>

    <footer class="blog-footer">
      © 瑠璃フクロウ ｜ X：<a href="https://x.com/rurifukuro">@rurifukuro</a> ｜
      お問い合わせ：<a href="mailto:rurifukuro@gmail.com">rurifukuro@gmail.com</a>
    </footer>
  </div>
</BaseLayout>

<style>
  .blog-wrap {
    max-width: 720px;
    margin: 0 auto;
    padding: 28px 24px 64px;
  }

  .blog-nav {
    margin-bottom: 28px;
  }

  .blog-nav a {
    font-size: 13px;
    color: #9fb0d4;
  }

  .blog-nav a:hover {
    color: #cdd9f0;
    text-decoration: none;
  }

  .article-header {
    margin-bottom: 36px;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 13px;
    color: var(--text-dim);
    margin-bottom: 12px;
  }

  .article-category {
    background: rgba(245, 130, 31, 0.15);
    color: #f5821f;
    padding: 2px 10px;
    border-radius: 12px;
    font-size: 12px;
    font-weight: 700;
  }

  .article-title {
    font-size: 28px;
    font-weight: 800;
    line-height: 1.4;
    margin-bottom: 14px;
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .article-body {
    font-size: 16px;
    line-height: 1.85;
    color: #e4ebf7;
  }

  .article-body :global(h2) {
    font-size: 22px;
    font-weight: 800;
    color: #fff;
    margin: 40px 0 16px;
    padding-bottom: 8px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .article-body :global(h3) {
    font-size: 18px;
    font-weight: 700;
    color: #fff;
    margin: 32px 0 12px;
  }

  .article-body :global(p) {
    margin-bottom: 20px;
  }

  .article-body :global(ul),
  .article-body :global(ol) {
    margin: 0 0 20px 24px;
  }

  .article-body :global(li) {
    margin-bottom: 6px;
  }

  .article-body :global(strong) {
    color: #fff;
    font-weight: 700;
  }

  .article-body :global(hr) {
    border: none;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    margin: 36px 0;
  }

  .article-body :global(blockquote) {
    border-left: 3px solid var(--orange);
    padding: 12px 16px;
    margin: 20px 0;
    background: rgba(255, 255, 255, 0.04);
    border-radius: 0 12px 12px 0;
    color: #cdd8ef;
  }

  .blog-footer {
    text-align: center;
    font-size: 12px;
    color: var(--text-dim);
    margin-top: 52px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: 24px;
  }

  .blog-footer a {
    color: #9fb0d4;
  }

  @media (max-width: 480px) {
    .article-title {
      font-size: 22px;
    }
  }
</style>
