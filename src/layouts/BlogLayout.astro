---
import BaseLayout from './BaseLayout.astro';
import AppCTA from '../components/AppCTA.astro';
import TagBadge from '../components/TagBadge.astro';
import PopularSidebar from '../components/PopularSidebar.astro';
import RecommendedSidebar from '../components/RecommendedSidebar.astro';
import { isDisplayTag } from '../utils/tags';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  category: string;
  targetApp: 'torehan' | 'urehan' | 'both';
  slug: string;
}

const { title, description, date, tags, category, targetApp, slug } = Astro.props;

const displayTags = tags.filter(isDisplayTag);

const dateStr = date.toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${title}｜瑠璃フクロウ`} description={description} ogType="article">
  <div class="page">
    <nav class="nav">
      <div class="nav-inner">
        <a class="nav-logo" href="/">瑠璃フクロウ</a>
        <div class="breadcrumb">
          <a class="breadcrumb-link" href="/blog/">ブログ</a>
          <span class="breadcrumb-sep">&rsaquo;</span>
          <span class="breadcrumb-current">{category}</span>
        </div>
      </div>
    </nav>

    <div class="blog-layout">
      <aside class="sidebar sidebar-left">
        <PopularSidebar />
      </aside>

      <main class="main-content">
        <article class="article-wrap">
          <header class="article-header">
            <span class="article-category">{category}</span>
            <h1 class="article-title">{title}</h1>
            <div class="article-meta">
              <time datetime={date.toISOString().slice(0, 10)}>{dateStr}</time>
            </div>
          </header>

          <div class="article-body">
            <slot />
          </div>

          <div class="article-tags">
            {displayTags.map((tag) => <TagBadge tag={tag} />)}
          </div>

          <AppCTA app={targetApp} />
        </article>
      </main>

      <aside class="sidebar sidebar-right">
        <RecommendedSidebar currentSlug={slug} currentTags={tags} />
      </aside>
    </div>

    <footer class="footer">
      <div class="footer-inner">
        <div class="footer-brand">瑠璃フクロウ</div>
        <div class="footer-links">
          <a href="https://x.com/rurifukuro">@rurifukuro</a>
          <span class="footer-dot">&middot;</span>
          <a href="mailto:rurifukuro@gmail.com">rurifukuro@gmail.com</a>
        </div>
        <p class="footer-copy">&copy; 瑠璃フクロウ</p>
      </div>
    </footer>
  </div>
</BaseLayout>

<style>
  .page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(255, 255, 255, .92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 14px 24px;
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .nav-logo {
    font-size: 16px;
    font-weight: 800;
    color: var(--text);
    letter-spacing: -.01em;
    flex-shrink: 0;
  }

  .nav-logo:hover {
    text-decoration: none;
    color: var(--accent);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--text-muted);
    min-width: 0;
  }

  .breadcrumb-link {
    color: var(--text-muted);
    flex-shrink: 0;
  }

  .breadcrumb-link:hover {
    color: var(--text);
    text-decoration: none;
  }

  .breadcrumb-sep {
    color: var(--text-dim);
    flex-shrink: 0;
  }

  .breadcrumb-current {
    color: var(--text-secondary);
    font-weight: 600;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .article-wrap {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 40px 36px 48px;
    box-shadow: var(--shadow-xs);
  }

  .article-header {
    margin-bottom: 36px;
    padding-bottom: 28px;
    border-bottom: 1px solid var(--border-light);
  }

  .article-category {
    display: inline-block;
    font-size: 12px;
    font-weight: 700;
    color: var(--accent);
    background: var(--accent-soft);
    padding: 4px 14px;
    border-radius: 4px;
    letter-spacing: .04em;
    margin-bottom: 16px;
  }

  .article-title {
    font-size: 28px;
    font-weight: 900;
    line-height: 1.45;
    letter-spacing: -.02em;
    margin-bottom: 14px;
    color: var(--text);
  }

  .article-meta {
    font-size: 14px;
    color: var(--text-muted);
  }

  .article-body {
    font-size: 16px;
    line-height: 1.9;
    color: var(--text-secondary);
  }

  .article-body :global(h2) {
    font-size: 21px;
    font-weight: 800;
    color: var(--text);
    margin: 48px 0 18px;
    padding-bottom: 10px;
    border-bottom: 2px solid var(--accent);
    letter-spacing: -.01em;
  }

  .article-body :global(h3) {
    font-size: 17px;
    font-weight: 700;
    color: var(--text);
    margin: 36px 0 12px;
    padding-left: 14px;
    border-left: 3px solid var(--border);
  }

  .article-body :global(p) {
    margin-bottom: 22px;
  }

  .article-body :global(ul),
  .article-body :global(ol) {
    margin: 0 0 22px 20px;
  }

  .article-body :global(li) {
    margin-bottom: 8px;
    color: var(--text-secondary);
  }

  .article-body :global(li::marker) {
    color: var(--accent);
  }

  .article-body :global(strong) {
    color: var(--text);
    font-weight: 700;
  }

  .article-body :global(hr) {
    border: none;
    height: 1px;
    background: var(--border);
    margin: 40px 0;
  }

  .article-body :global(blockquote) {
    border-left: 4px solid var(--accent);
    padding: 18px 22px;
    margin: 24px 0;
    background: var(--accent-soft);
    border-radius: 0 8px 8px 0;
    color: var(--text);
    font-size: 15px;
  }

  .article-body :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-color: var(--accent-border);
    text-underline-offset: 3px;
    transition: text-decoration-color .15s;
  }

  .article-body :global(a:hover) {
    text-decoration-color: var(--accent);
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    padding-top: 28px;
    margin-top: 40px;
    border-top: 1px solid var(--border-light);
  }

  .footer {
    background: #1a1a2e;
    color: #b5b5c8;
    padding: 40px 24px;
    margin-top: auto;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
  }

  .footer-brand {
    font-size: 16px;
    font-weight: 800;
    color: #fff;
    margin-bottom: 10px;
  }

  .footer-links {
    font-size: 13px;
    margin-bottom: 16px;
  }

  .footer-links a {
    color: #8c8ca1;
    transition: color .15s;
  }

  .footer-links a:hover {
    color: #fff;
    text-decoration: none;
  }

  .footer-dot {
    margin: 0 8px;
    opacity: .4;
  }

  .footer-copy {
    font-size: 12px;
    color: #666;
  }

  @media (max-width: 1080px) {
    .article-wrap {
      padding: 32px 28px 40px;
    }
  }

  @media (max-width: 480px) {
    .article-title {
      font-size: 22px;
    }
    .article-body :global(h2) {
      font-size: 19px;
    }
    .article-wrap {
      padding: 28px 20px 36px;
      border-radius: var(--radius);
    }
  }
</style>
