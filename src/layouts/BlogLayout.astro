---
import BaseLayout from './BaseLayout.astro';
import AppCTA from '../components/AppCTA.astro';
import TagBadge from '../components/TagBadge.astro';
import { isDisplayTag } from '../utils/tags';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  category: string;
  targetApp: 'torehan' | 'urehan' | 'both';
}

const { title, description, date, tags, category, targetApp } = Astro.props;

const displayTags = tags.filter(isDisplayTag);

const dateStr = date.toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${title}｜瑠璃フクロウ`} description={description} ogType="article">
  <div class="page">
    <div class="top-bar">
      <div class="top-inner">
        <a class="back" href="/blog/">
          <span class="back-arrow">←</span>
          記事一覧
        </a>
      </div>
    </div>

    <article class="article">
      <header class="article-header">
        <div class="article-meta">
          <time datetime={date.toISOString().slice(0, 10)}>{dateStr}</time>
          <span class="sep">·</span>
          <span class="article-category">{category}</span>
        </div>
        <h1 class="article-title">{title}</h1>
        <div class="article-tags">
          {displayTags.map((tag) => <TagBadge tag={tag} />)}
        </div>
      </header>

      <div class="article-body">
        <slot />
      </div>

      <AppCTA app={targetApp} />
    </article>

    <footer class="page-footer">
      © 瑠璃フクロウ ｜ <a href="https://x.com/rurifukuro">@rurifukuro</a> ｜
      <a href="mailto:rurifukuro@gmail.com">rurifukuro@gmail.com</a>
    </footer>
  </div>
</BaseLayout>

<style>
  .page {
    min-height: 100vh;
  }

  .top-bar {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(10, 22, 40, .85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255,255,255,.05);
  }

  .top-inner {
    max-width: 720px;
    margin: 0 auto;
    padding: 12px 24px;
  }

  .back {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-weight: 600;
    color: var(--text-muted);
    transition: color .15s;
  }

  .back:hover {
    color: var(--text);
    text-decoration: none;
  }

  .back-arrow {
    font-size: 12px;
  }

  .article {
    max-width: 720px;
    margin: 0 auto;
    padding: 40px 24px 48px;
  }

  .article-header {
    margin-bottom: 40px;
    padding-bottom: 32px;
    border-bottom: 1px solid rgba(255,255,255,.06);
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--text-dim);
    margin-bottom: 16px;
  }

  .sep {
    color: var(--text-dim);
    opacity: .5;
  }

  .article-category {
    color: var(--orange);
    font-weight: 700;
    font-size: 12px;
  }

  .article-title {
    font-size: 30px;
    font-weight: 900;
    line-height: 1.4;
    margin-bottom: 16px;
    letter-spacing: -.02em;
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .article-body {
    font-size: 16px;
    line-height: 1.9;
    color: var(--text-sub);
  }

  .article-body :global(h2) {
    font-size: 22px;
    font-weight: 800;
    color: var(--text);
    margin: 48px 0 16px;
    padding-left: 14px;
    border-left: 3px solid var(--orange);
    letter-spacing: -.01em;
  }

  .article-body :global(h3) {
    font-size: 18px;
    font-weight: 700;
    color: var(--text);
    margin: 36px 0 12px;
  }

  .article-body :global(p) {
    margin-bottom: 20px;
  }

  .article-body :global(ul),
  .article-body :global(ol) {
    margin: 0 0 20px 24px;
  }

  .article-body :global(li) {
    margin-bottom: 8px;
    color: var(--text-sub);
  }

  .article-body :global(li::marker) {
    color: var(--orange);
  }

  .article-body :global(strong) {
    color: var(--text);
    font-weight: 700;
  }

  .article-body :global(hr) {
    border: none;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,.1), transparent);
    margin: 40px 0;
  }

  .article-body :global(blockquote) {
    border-left: 3px solid var(--orange);
    padding: 16px 20px;
    margin: 24px 0;
    background: linear-gradient(135deg, rgba(245,130,31,.06) 0%, rgba(255,255,255,.02) 100%);
    border-radius: 0 12px 12px 0;
    color: var(--text);
    font-size: 15px;
  }

  .article-body :global(a) {
    color: var(--orange);
    text-decoration: underline;
    text-decoration-color: rgba(245,130,31,.3);
    text-underline-offset: 3px;
    transition: text-decoration-color .15s;
  }

  .article-body :global(a:hover) {
    text-decoration-color: var(--orange);
  }

  .page-footer {
    text-align: center;
    font-size: 12px;
    color: var(--text-dim);
    padding: 0 24px 32px;
  }

  .page-footer a {
    color: var(--text-muted);
  }

  @media (max-width: 480px) {
    .article-title {
      font-size: 24px;
    }
    .article-body :global(h2) {
      font-size: 20px;
    }
  }
</style>
