---
interface Props {
  tag: string;
  linked?: boolean;
}

const { tag, linked = true } = Astro.props;
---

{linked ? (
  <a class="tag" href={`/blog/tag/${encodeURIComponent(tag)}/`}>{tag}</a>
) : (
  <span class="tag">{tag}</span>
)}

<style>
  .tag {
    display: inline-block;
    font-size: 12px;
    font-weight: 600;
    color: var(--text-muted);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: 4px 12px;
    border-radius: 20px;
    text-decoration: none;
    transition: all 0.2s ease;
    letter-spacing: .01em;
  }

  a.tag:hover {
    color: var(--orange);
    border-color: rgba(245, 130, 31, 0.3);
    background: rgba(245, 130, 31, 0.08);
    text-decoration: none;
  }
</style>
