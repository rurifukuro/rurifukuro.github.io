---
interface Props {
  tag: string;
  linked?: boolean;
}

const { tag, linked = true } = Astro.props;
---

{linked ? (
  <a class="tag" href={`/blog/tag/${encodeURIComponent(tag)}/`}>{tag}</a>
) : (
  <span class="tag">{tag}</span>
)}

<style>
  .tag {
    display: inline-block;
    font-size: 12px;
    font-weight: 600;
    color: var(--text-muted);
    background: var(--bg, #f5f6fa);
    border: 1px solid var(--border, #e5e7eb);
    padding: 4px 14px;
    border-radius: 20px;
    text-decoration: none;
    transition: all 0.2s ease;
    letter-spacing: .01em;
  }

  a.tag:hover {
    color: var(--accent, #f5821f);
    border-color: var(--accent-border, rgba(245, 130, 31, 0.25));
    background: var(--accent-soft, rgba(245, 130, 31, 0.06));
    text-decoration: none;
  }
</style>
