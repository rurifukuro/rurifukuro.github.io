---
interface Props {
  app: 'torehan' | 'urehan' | 'both';
}

const { app } = Astro.props;

const torehan = {
  name: 'とれはんっ！',
  desc: '同人イベント攻略アプリ。会場マップ・AI読取・予算管理・サークル分担をスマホ1つで。',
  url: 'https://apps.apple.com/jp/app/id6776913607',
  page: '/torehan/',
};

const urehan = {
  name: 'レジさぽっ！',
  desc: '即売会サークルのためのレジ・会計アプリ。秒会計・取り置き予約・売上集計・確定申告サポート。',
  url: 'https://apps.apple.com/app/id6786309116',
  page: '/urehan/',
};

const apps = app === 'both' ? [torehan, urehan] : app === 'torehan' ? [torehan] : [urehan];
---

<aside class="cta-section">
  <div class="cta-divider">
    <span class="cta-divider-line"></span>
    <span class="cta-divider-text">関連アプリ</span>
    <span class="cta-divider-line"></span>
  </div>
  {apps.map((a) => (
    <div class="cta-box">
      <div class="cta-top">
        <span class="cta-label">無料</span>
        <a class="cta-detail" href={a.page}>詳しく見る →</a>
      </div>
      <h3 class="cta-name">{a.name}</h3>
      <p class="cta-desc">{a.desc}</p>
      <a class="cta-btn" href={a.url}>
        App Store で無料ダウンロード
      </a>
    </div>
  ))}
</aside>

<style>
  .cta-section {
    margin-top: 56px;
    padding-top: 8px;
  }

  .cta-divider {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 24px;
  }

  .cta-divider-line {
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .cta-divider-text {
    font-size: 13px;
    font-weight: 700;
    color: var(--text-muted);
    letter-spacing: .08em;
    white-space: nowrap;
  }

  .cta-box {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 24px;
    margin-bottom: 12px;
    transition: box-shadow 0.2s;
  }

  .cta-box:hover {
    box-shadow: var(--shadow-sm);
  }

  .cta-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 10px;
  }

  .cta-label {
    font-size: 11px;
    font-weight: 700;
    color: #fff;
    background: var(--accent);
    padding: 2px 10px;
    border-radius: 4px;
    letter-spacing: .04em;
  }

  .cta-detail {
    font-size: 12px;
    color: var(--text-muted);
    transition: color .15s;
  }

  .cta-detail:hover {
    color: var(--accent);
    text-decoration: none;
  }

  .cta-name {
    font-size: 20px;
    font-weight: 800;
    color: var(--text);
    margin-bottom: 6px;
  }

  .cta-desc {
    font-size: 14px;
    color: var(--text-secondary);
    margin-bottom: 20px;
    line-height: 1.7;
  }

  .cta-btn {
    display: block;
    text-align: center;
    text-decoration: none;
    font-weight: 700;
    font-size: 15px;
    padding: 14px 18px;
    border-radius: var(--radius-sm);
    background: var(--text);
    color: #fff;
    transition: all 0.2s ease;
  }

  .cta-btn:hover {
    text-decoration: none;
    opacity: 0.85;
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
  }

  .cta-btn:active {
    transform: scale(0.98);
  }
</style>
