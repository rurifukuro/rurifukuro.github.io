---
import TagBadge from './TagBadge.astro';
import { isDisplayTag } from '../utils/tags';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  category: string;
  slug: string;
}

const { title, description, date, tags, category, slug } = Astro.props;

const displayTags = tags.filter(isDisplayTag).slice(0, 4);

const dateStr = date.toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<a class="card" href={`/blog/${slug}/`}>
  <div class="card-category-bar">
    <span class="card-category">{category}</span>
  </div>
  <h2 class="card-title">{title}</h2>
  <p class="card-desc">{description}</p>
  <div class="card-bottom">
    <div class="card-tags">
      {displayTags.map((tag) => <TagBadge tag={tag} linked={false} />)}
    </div>
    <time class="card-date" datetime={date.toISOString().slice(0, 10)}>{dateStr}</time>
  </div>
</a>

<style>
  .card {
    display: block;
    text-decoration: none;
    color: var(--text);
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 28px;
    transition: all 0.25s ease;
    box-shadow: var(--shadow-xs);
  }

  .card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-hover);
    border-color: var(--accent-border);
    text-decoration: none;
  }

  .card-category-bar {
    margin-bottom: 12px;
  }

  .card-category {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    color: var(--accent);
    background: var(--accent-soft);
    padding: 3px 12px;
    border-radius: 4px;
    letter-spacing: .04em;
  }

  .card-title {
    font-size: 18px;
    font-weight: 800;
    line-height: 1.5;
    margin-bottom: 10px;
    letter-spacing: -.01em;
    color: var(--text);
  }

  .card-desc {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 16px;
  }

  .card-bottom {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 12px;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    flex: 1;
  }

  .card-date {
    font-size: 12px;
    color: var(--text-dim);
    white-space: nowrap;
    flex-shrink: 0;
  }

  @media (max-width: 480px) {
    .card {
      padding: 22px;
    }
    .card-title {
      font-size: 16px;
    }
    .card-bottom {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
