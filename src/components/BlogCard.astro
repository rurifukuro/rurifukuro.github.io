---
import TagBadge from './TagBadge.astro';
import { isDisplayTag } from '../utils/tags';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  category: string;
  slug: string;
}

const { title, description, date, tags, category, slug } = Astro.props;

const displayTags = tags.filter(isDisplayTag).slice(0, 5);

const dateStr = date.toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<a class="card" href={`/blog/${slug}/`}>
  <div class="card-inner">
    <div class="card-meta">
      <time datetime={date.toISOString().slice(0, 10)}>{dateStr}</time>
      <span class="card-category">{category}</span>
    </div>
    <h2 class="card-title">{title}</h2>
    <p class="card-desc">{description}</p>
    <div class="card-tags">
      {displayTags.map((tag) => <TagBadge tag={tag} linked={false} />)}
    </div>
  </div>
  <div class="card-arrow">→</div>
</a>

<style>
  .card {
    position: relative;
    display: block;
    text-decoration: none;
    color: var(--text);
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 16px;
    padding: 1px;
    transition: all 0.25s ease;
  }

  .card::before {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: 17px;
    background: linear-gradient(135deg, transparent 0%, rgba(245,130,31,.2) 50%, transparent 100%);
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
    z-index: 0;
  }

  .card:hover {
    transform: translateY(-3px);
    background: var(--card-hover);
    box-shadow: 0 8px 32px rgba(0,0,0,.3), 0 0 0 1px rgba(245,130,31,.1);
    text-decoration: none;
  }

  .card:hover::before {
    opacity: 1;
  }

  .card-inner {
    position: relative;
    z-index: 1;
    padding: 24px 48px 24px 24px;
  }

  .card-arrow {
    position: absolute;
    right: 20px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 16px;
    color: var(--text-dim);
    transition: all 0.25s ease;
    z-index: 1;
  }

  .card:hover .card-arrow {
    color: var(--orange);
    transform: translateY(-50%) translateX(3px);
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 12px;
    color: var(--text-dim);
    margin-bottom: 10px;
  }

  .card-category {
    background: rgba(245, 130, 31, 0.12);
    color: var(--orange);
    padding: 2px 10px;
    border-radius: 10px;
    font-size: 11px;
    font-weight: 700;
  }

  .card-title {
    font-size: 18px;
    font-weight: 800;
    line-height: 1.5;
    margin-bottom: 8px;
    letter-spacing: -.01em;
  }

  .card-desc {
    font-size: 13.5px;
    color: var(--text-sub);
    line-height: 1.65;
    margin-bottom: 14px;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  @media (max-width: 480px) {
    .card-title {
      font-size: 16px;
    }
    .card-inner {
      padding: 20px 40px 20px 20px;
    }
  }
</style>
